---
export interface Props {
  t: Record<string, any>;
  id?: string;
}

const { t, id } = Astro.props;
const points = t.whyus.pillars;
---

<section id={id} class="py-24 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 lg:gap-20">
      {
        points.map((point: any) => (
          <div>
            <span class="block font-heading text-6xl lg:text-7xl font-normal text-accent/15 mb-6 leading-none">
              {point.num}
            </span>
            <h3 class="font-heading text-xl font-semibold text-text-primary mb-3">
              {point.title}
            </h3>
            <p class="font-body text-sm text-text-secondary leading-relaxed">
              {point.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
