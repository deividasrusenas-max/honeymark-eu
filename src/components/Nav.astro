---
export interface Props {
  locale: string;
  t: Record<string, any>;
}

const { locale, t } = Astro.props;
const navItems = [
  { href: `/${locale}/#produktai`, label: t.nav.products },
  { href: `/${locale}/#apie`, label: t.nav.about },
  { href: `/${locale}/#kontaktai`, label: t.nav.contact },
];

const locales = [
  { code: 'en', label: 'EN' },
  { code: 'lt', label: 'LT' },
  { code: 'lv', label: 'LV' },
  { code: 'et', label: 'EE' },
];

const currentPath = Astro.url.pathname;
const currentLocaleLabel = locales.find((loc) => loc.code === locale)?.label || locale;
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 bg-white transition-shadow duration-200"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a
        href={`/${locale}/`}
        class="text-text-primary font-body font-semibold text-[15px] tracking-[-0.01em]"
      >
        Honeymark
      </a>

      <div class="hidden md:flex items-center gap-8">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="font-body text-sm text-text-primary hover:text-accent transition-colors duration-200"
              style="letter-spacing: 0.02em;"
            >
              {item.label}
            </a>
          ))
        }

        <!-- Language switcher -->
        <div class="relative" id="lang-switcher">
          <button
            type="button"
            id="lang-toggle"
            class="flex items-center gap-1 font-body text-sm text-text-primary hover:text-accent transition-colors duration-200"
            aria-expanded="false"
            aria-haspopup="true"
          >
            <span class="uppercase">{currentLocaleLabel}</span>
            <svg
              class="w-3 h-3 text-text-secondary transition-transform duration-200"
              id="lang-chevron"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"
              />
            </svg>
          </button>

          <div
            id="lang-dropdown"
            class="absolute right-0 mt-2 w-20 bg-white border border-border rounded shadow-sm opacity-0 translate-y-1 pointer-events-none transition-all duration-200 origin-top-right"
          >
            {
              locales.map((loc) => {
                const href = currentPath.replace(
                  /^\/(en|lt|lv|et)/,
                  `/${loc.code}`
                );
                const isActive = loc.code === locale;
                return (
                  <a
                    href={href}
                    class={`block px-3 py-2 font-body text-sm transition-colors duration-200 ${
                      isActive
                        ? 'text-accent font-semibold'
                        : 'text-text-primary hover:text-accent'
                    }`}
                  >
                    {loc.label}
                  </a>
                );
              })
            }
          </div>
        </div>

        <a
          href={`/${locale}/contact/`}
          class="btn-pill bg-text-primary text-white hover:bg-text-primary/90"
        >
          {t.nav.cta}
        </a>
      </div>

      <div class="md:hidden flex items-center gap-3">
        <!-- Mobile language switcher -->
        <div class="relative" id="lang-switcher-mobile">
          <button
            type="button"
            id="lang-toggle-mobile"
            class="flex items-center gap-0.5 font-body text-sm text-text-primary hover:text-accent transition-colors duration-200"
            aria-expanded="false"
            aria-haspopup="true"
          >
            <span class="uppercase">{currentLocaleLabel}</span>
            <svg
              class="w-2.5 h-2.5 text-text-secondary transition-transform duration-200"
              id="lang-chevron-mobile"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"
              />
            </svg>
          </button>

          <div
            id="lang-dropdown-mobile"
            class="absolute right-0 mt-2 w-20 bg-white border border-border rounded shadow-sm opacity-0 translate-y-1 pointer-events-none transition-all duration-200 origin-top-right"
          >
            {
              locales.map((loc) => {
                const href = currentPath.replace(
                  /^\/(en|lt|lv|et)/,
                  `/${loc.code}`
                );
                const isActive = loc.code === locale;
                return (
                  <a
                    href={href}
                    class={`block px-3 py-2 font-body text-sm transition-colors duration-200 ${
                      isActive
                        ? 'text-accent font-semibold'
                        : 'text-text-primary hover:text-accent'
                    }`}
                  >
                    {loc.label}
                  </a>
                );
              })
            }
          </div>
        </div>

        <a
          href={`/${locale}/contact/`}
          class="btn-pill bg-text-primary text-white text-sm"
        >
          {t.nav.cta}
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  function setupLangSwitcher(toggleId: string, dropdownId: string, chevronId: string) {
    const toggle = document.getElementById(toggleId);
    const dropdown = document.getElementById(dropdownId);
    const chevron = document.getElementById(chevronId);
    if (!toggle || !dropdown || !chevron) return;

    let isOpen = false;

    const open = () => {
      isOpen = true;
      toggle.setAttribute('aria-expanded', 'true');
      dropdown.classList.remove('opacity-0', 'translate-y-1', 'pointer-events-none');
      dropdown.classList.add('opacity-100', 'translate-y-0');
      chevron.classList.add('rotate-180');
    };

    const close = () => {
      isOpen = false;
      toggle.setAttribute('aria-expanded', 'false');
      dropdown.classList.add('opacity-0', 'translate-y-1', 'pointer-events-none');
      dropdown.classList.remove('opacity-100', 'translate-y-0');
      chevron.classList.remove('rotate-180');
    };

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      isOpen ? close() : open();
    });

    document.addEventListener('click', (e) => {
      if (isOpen && !toggle.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
        close();
      }
    });
  }

  setupLangSwitcher('lang-toggle', 'lang-dropdown', 'lang-chevron');
  setupLangSwitcher('lang-toggle-mobile', 'lang-dropdown-mobile', 'lang-chevron-mobile');
</script>

<script>
  const nav = document.getElementById('main-nav');
  if (nav) {
    const onScroll = () => {
      if (window.scrollY > 4) {
        nav.style.boxShadow = '0 1px 0 #E8E8E4';
      } else {
        nav.style.boxShadow = 'none';
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
