---
export interface Props {
  title: string;
  subtitle: string;
  cta1: string;
  cta2: string;
  locale: string;
  t: Record<string, any>;
}

const { subtitle, cta1, cta2, locale, t } = Astro.props;

// Dynamic years calculation
const foundedYear = 2012;
const currentYear = new Date().getFullYear();
const yearsActive = currentYear - foundedYear;
const yearsBadge = `${yearsActive} ${t.hero.badge3suffix}`;
---

<section class="relative min-h-screen bg-white pt-8 md:pt-16">
  <div class="max-w-7xl mx-auto">
    <div class="grid lg:grid-cols-[55fr_45fr] min-h-[calc(100vh-64px)]">
      <!-- Left column -->
      <div class="flex flex-col justify-center px-6 lg:px-8 py-16 lg:py-24">
        <p
          class="font-body text-[11px] font-medium uppercase tracking-[0.15em] text-accent mb-8"
        >
          {t.hero.badge}
        </p>

        <h1
          class="font-heading font-bold text-text-primary leading-[1.05] mb-8"
          style="font-size: clamp(2.5rem, 5.5vw, 4.5rem);"
        >
          {t.hero.titleLine1}<br />
          <span class="italic text-accent">{t.hero.titleLine2}</span> —<br />
          {t.hero.titleLine3}
        </h1>

        <p
          class="font-body text-lg text-text-secondary max-w-[420px] mb-10 leading-relaxed"
        >
          {subtitle}
        </p>

        <div class="flex flex-wrap items-center gap-4 mb-14">
          <a
            href={`/${locale}/products/`}
            class="btn-pill bg-text-primary text-white hover:bg-text-primary/85"
          >
            {cta1}
          </a>
          <a
            href={`/${locale}/contact/`}
            class="btn-pill bg-white text-text-primary border border-border hover:border-accent hover:text-accent"
          >
            {cta2}
          </a>
        </div>

        <div class="flex items-center gap-3 text-[13px] text-text-secondary font-body">
          <span>{t.hero.badge1}</span>
          <span class="text-border">·</span>
          <span>{t.hero.badge2}</span>
          <span class="text-border">·</span>
          <span>{yearsBadge}</span>
        </div>
      </div>

      <!-- Right column — full-bleed image -->
      <div class="relative hidden lg:block">
        <div class="absolute inset-0">
          <img
            src="https://images.unsplash.com/photo-1558642452-9d2a7deb7f62?w=900&q=80"
            alt={t.hero.imageAlt}
            class="w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile image -->
  <div class="lg:hidden px-6 pb-16">
    <img
      src="https://images.unsplash.com/photo-1558642452-9d2a7deb7f62?w=900&q=80"
      alt={t.hero.imageAlt}
      class="w-full aspect-[4/3] object-cover"
      loading="eager"
      fetchpriority="high"
    />
  </div>
</section>