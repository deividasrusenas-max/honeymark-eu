---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  return [
    { params: { locale: 'lt' } },
    { params: { locale: 'lv' } },
    { params: { locale: 'et' } },
    { params: { locale: 'en' } },
  ];
}

const { locale } = Astro.params;
const translations = await import(`../../i18n/${locale}.json`);
const t = translations.default;

const title = `${t.contact.title} | Honeymark`;
const description = t.contact.subtitle;
---

<BaseLayout title={title} description={description} locale={locale}>
  <Nav locale={locale} t={t} />

  <section class="pt-32 pb-20 lg:pt-48 lg:pb-28 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1
          class="font-heading font-bold text-text-primary mb-6"
          style="font-size: clamp(2.5rem, 5vw, 4rem);"
        >
          {t.contact.title}
        </h1>
      </div>
    </div>
  </section>

  <section class="pb-24 lg:pb-32 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16">
        <!-- Left column — contact details -->
        <div>
          <h2
            class="font-heading font-bold text-text-primary mb-4"
            style="font-size: clamp(1.5rem, 2.5vw, 2rem);"
          >
            {t.contact.heading}
          </h2>
          <p class="font-body text-text-secondary leading-relaxed mb-12 max-w-md">
            {t.contact.subtitle}
          </p>

          <div class="space-y-10">
            <!-- Email -->
            <div class="flex items-start gap-5">
              <div class="w-12 h-12 bg-warm-white flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-body text-sm font-medium text-text-primary mb-1">{t.contact.emailLabel}</h3>
                <a href={`mailto:${t.contact.email}`} class="font-body text-sm text-text-secondary hover:text-accent transition-colors">
                  {t.contact.email}
                </a>
              </div>
            </div>

            <!-- Phone -->
            <div class="flex items-start gap-5">
              <div class="w-12 h-12 bg-warm-white flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-body text-sm font-medium text-text-primary mb-1">{t.contact.phoneLabel}</h3>
                <a href={`tel:${t.contact.phone.replace(/\s/g, '')}`} class="font-body text-sm text-text-secondary hover:text-accent transition-colors">
                  {t.contact.phone}
                </a>
              </div>
            </div>

            <!-- WhatsApp -->
            <div class="flex items-start gap-5">
              <div class="w-12 h-12 bg-warm-white flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-body text-sm font-medium text-text-primary mb-1">{t.contact.whatsappLabel}</h3>
                <a href={`https://wa.me/${t.contact.phone.replace(/\D/g, '')}`} target="_blank" rel="noopener noreferrer" class="font-body text-sm text-text-secondary hover:text-accent transition-colors">
                  {t.contact.phone}
                </a>
              </div>
            </div>

            <!-- Location -->
            <div class="flex items-start gap-5">
              <div class="w-12 h-12 bg-warm-white flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-body text-sm font-medium text-text-primary mb-1">{t.contact.locationLabel}</h3>
                <p class="font-body text-sm text-text-secondary">{t.contact.location}</p>
              </div>
            </div>
          </div>

          <!-- Response time badge -->
          <div class="mt-12 inline-flex items-center gap-2 px-4 py-3 bg-warm-white border border-border rounded">
            <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="font-body text-sm text-text-secondary">{t.contact.responseTime}</span>
          </div>

          <!-- Area served -->
          <div class="mt-6 inline-flex items-center gap-2 px-4 py-3 bg-white border border-border rounded">
            <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="font-body text-sm text-text-secondary">{t.contact.areaServed}</span>
          </div>
        </div>

        <!-- Right column — trust signals -->
        <div>
          <div class="space-y-5 mb-12">
            <!-- Trust badge 1 -->
            <div class="flex items-center gap-4 px-5 py-4 bg-warm-white border border-border rounded">
              <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="font-body text-sm text-text-primary font-medium">{t.contact.trustBadge1}</span>
            </div>
            <!-- Trust badge 2 -->
            <div class="flex items-center gap-4 px-5 py-4 bg-warm-white border border-border rounded">
              <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="font-body text-sm text-text-primary font-medium">{t.contact.trustBadge2}</span>
            </div>
            <!-- Trust badge 3 -->
            <div class="flex items-center gap-4 px-5 py-4 bg-warm-white border border-border rounded">
              <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="font-body text-sm text-text-primary font-medium">{t.contact.trustBadge3}</span>
            </div>
          </div>

          <div>
            <p class="font-body text-text-secondary leading-relaxed text-[17px]">
              {t.contact.subtitle2}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer locale={locale} t={t} />
</BaseLayout>